# Copy to .env.local and fill in. Values prefixed NEXT_PUBLIC_ are exposed to
# the browser; the rest are server-only.

# FastAPI backend base URL. Local dev: http://localhost:8000.
# Production: the deployed Railway URL.
NEXT_PUBLIC_API_URL=http://localhost:8000

# This app's own origin. Used for absolute OG/Twitter image URLs (metadataBase)
# and as the Better Auth client baseURL. Local dev: http://localhost:3000.
# Production: the deployed Vercel domain (no trailing slash).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Better Auth ------------------------------------------------------------
# Auth server origin / JWT issuer. Normally the same as NEXT_PUBLIC_SITE_URL.
BETTER_AUTH_URL=http://localhost:3000

# Signing secret for sessions/JWTs. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Use a distinct value per environment; keep it out of version control.
BETTER_AUTH_SECRET=

# Neon Postgres connection string for Better Auth's tables (user/session/jwks/
# …). Create a free project at neon.tech and paste its connection string here.
# Separate from the app's Aurora database, which the FastAPI backend owns.
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require
