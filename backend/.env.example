# Database (local Docker Postgres from docker-compose.yml; published on 5433 to
# avoid clashing with a system Postgres on 5432)
DATABASE_URL=postgresql+psycopg://claimguard:claimguard@localhost:5433/claimguard

# Comma-separated CORS origins allowed to call the API from a browser. Add the
# deployed Vercel domain here in production (no trailing slash).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Better Auth (frontend) JWT verification. The API verifies the Bearer token
# against {BETTER_AUTH_URL}/api/auth/jwks and treats BETTER_AUTH_URL as the
# issuer. Set this to the frontend origin — http://localhost:3000 for local
# dev, the deployed Vercel domain in production.
BETTER_AUTH_URL=http://localhost:3000
# Optional explicit JWKS URL (defaults to {BETTER_AUTH_URL}/api/auth/jwks).
# BETTER_AUTH_JWKS_URL=

# LLM provider abstraction (TRD §3). Swap provider/model without code changes.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-8
# Faster/cheaper model for the appeal self-critique pass (keeps uploads snappy).
LLM_FAST_MODEL=claude-haiku-4-5

# Required when LLM_PROVIDER=anthropic. langchain-anthropic reads this directly.
ANTHROPIC_API_KEY=

# AgentMail email-in (TRD §5). All optional for the manual-upload demo path;
# required to go live with inbound denial emails.
AGENTMAIL_API_KEY=
# Svix signing secret (whsec_...) printed by provision_agentmail.py. When unset,
# the webhook handler skips signature verification (dev only).
AGENTMAIL_WEBHOOK_SECRET=
# Public https URL forwarding to this backend (e.g. an ngrok URL). Used by
# provision_agentmail.py to register the webhook target.
PUBLIC_BASE_URL=
# AgentMail REST base. Override only if pointing at a non-default environment.
# AGENTMAIL_BASE_URL=https://api.agentmail.to/v0

# --- Aurora (AWS free-tier "express configuration") --------------------------
# Free-tier Aurora has no VPC/password — access is via a managed internet
# access gateway using short-lived RDS IAM auth tokens over TLS. Set
# DB_IAM_AUTH=true to route the backend at Aurora (leave false for local
# Docker; DATABASE_URL above is then used). AWS credentials must be configured
# (aws configure) so boto3 can mint tokens.
DB_IAM_AUTH=false
DB_HOST=          # cluster writer endpoint, e.g. <id>.cluster-xxxx.<region>.rds.amazonaws.com
DB_PORT=5432
DB_USER=dbadmin
DB_NAME=postgres
# TLS mode for the Aurora connection (default require). Rarely changed.
# DB_SSLMODE=require
AWS_REGION=eu-north-1
# Public DNS servers to resolve DB_HOST when the local resolver can't reach the
# express gateway's .aws.dev zone. Leave empty if your resolver works.
DB_DNS_SERVERS=8.8.8.8,1.1.1.1

# AWS credentials for boto3 to mint RDS IAM tokens. Locally these come from
# `aws configure` (~/.aws/credentials) so you can leave them blank. On a hosted
# deploy (Railway) there is no aws configure — set them as service variables.
# The principal needs the rds-db:connect action on the cluster.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
