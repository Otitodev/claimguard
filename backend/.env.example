# Database (local Docker Postgres from docker-compose.yml)
DATABASE_URL=postgresql+psycopg://claimguard:claimguard@localhost:5432/claimguard

# LLM provider abstraction (TRD §3). Swap provider/model without code changes.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-8

# Required when LLM_PROVIDER=anthropic. langchain-anthropic reads this directly.
ANTHROPIC_API_KEY=

# AgentMail email-in (TRD §5). All optional for the manual-upload demo path;
# required to go live with inbound denial emails.
AGENTMAIL_API_KEY=
# Svix signing secret (whsec_...) printed by provision_agentmail.py. When unset,
# the webhook handler skips signature verification (dev only).
AGENTMAIL_WEBHOOK_SECRET=
# Public https URL forwarding to this backend (e.g. an ngrok URL). Used by
# provision_agentmail.py to register the webhook target.
PUBLIC_BASE_URL=
