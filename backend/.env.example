# Database (local Docker Postgres from docker-compose.yml)
DATABASE_URL=postgresql+psycopg://claimguard:claimguard@localhost:5432/claimguard

# LLM provider abstraction (TRD §3). Swap provider/model without code changes.
LLM_PROVIDER=anthropic
LLM_MODEL=claude-opus-4-8

# Required when LLM_PROVIDER=anthropic. langchain-anthropic reads this directly.
ANTHROPIC_API_KEY=

# AgentMail email-in (TRD §5). All optional for the manual-upload demo path;
# required to go live with inbound denial emails.
AGENTMAIL_API_KEY=
# Svix signing secret (whsec_...) printed by provision_agentmail.py. When unset,
# the webhook handler skips signature verification (dev only).
AGENTMAIL_WEBHOOK_SECRET=
# Public https URL forwarding to this backend (e.g. an ngrok URL). Used by
# provision_agentmail.py to register the webhook target.
PUBLIC_BASE_URL=

# --- Aurora (AWS free-tier "express configuration") --------------------------
# Free-tier Aurora has no VPC/password — access is via a managed internet
# access gateway using short-lived RDS IAM auth tokens over TLS. Set
# DB_IAM_AUTH=true to route the backend at Aurora (leave false for local
# Docker; DATABASE_URL above is then used). AWS credentials must be configured
# (aws configure) so boto3 can mint tokens.
DB_IAM_AUTH=false
DB_HOST=          # cluster writer endpoint, e.g. <id>.cluster-xxxx.<region>.rds.amazonaws.com
DB_PORT=5432
DB_USER=dbadmin
DB_NAME=postgres
AWS_REGION=eu-north-1
# Public DNS servers to resolve DB_HOST when the local resolver can't reach the
# express gateway's .aws.dev zone. Leave empty if your resolver works.
DB_DNS_SERVERS=8.8.8.8,1.1.1.1
